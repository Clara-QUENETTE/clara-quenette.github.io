<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
    <title>doc.pdf</title>

<!-- This snippet is used in the Firefox extension (included from viewer.html) -->
<script src="resource://pdf.js/build/pdf.mjs" type="module"></script>

  <link rel="stylesheet" href="resource://pdf.js/web/viewer.css">
  <link rel="localization" href="toolkit/pdfviewer/viewer.ftl">

  <script src="resource://pdf.js/web/viewer.mjs" type="module"></script>
  </head>

  <body tabindex="0">
    <div id="outerContainer">
      <span id="viewer-alert" class="visuallyHidden" role="alert"></span>

      <div id="mainContainer">
        <div class="toolbar">
          <div id="toolbarContainer">
            <div id="toolbarViewer" class="toolbarHorizontalGroup">
              <div id="toolbarViewerLeft" class="toolbarHorizontalGroup">
                <button id="viewsManagerToggleButton" class="toolbarButton" type="button" tabindex="0" data-l10n-id="pdfjs-toggle-views-manager-button" aria-expanded="false" aria-haspopup="true" aria-controls="viewsManager" title="Afficher/Masquer le panneau latéral">
                  <span data-l10n-id="pdfjs-toggle-views-manager-button-label">Afficher/Masquer le panneau latéral</span>
                </button>
                <div id="viewsManager" class="menuContainer sidebar" hidden="" role="dialog" aria-describedby="viewsManagerHeaderLabel" data-l10n-id="pdfjs-views-manager-sidebar" aria-label="Panneau latéral">
                  <div id="viewsManagerHeader" role="heading" aria-level="2">
                    <div id="viewsManagerTitle">
                      <div id="viewsManagerSelector">
                        <button class="toolbarButton viewsManagerButton hasPopupMenu" type="button" id="viewsManagerSelectorButton" tabindex="0" data-l10n-id="pdfjs-views-manager-view-selector-button" aria-expanded="false" aria-haspopup="listbox" aria-controls="viewsManagerSelectorOptions" title="Vues">
                          <span data-l10n-id="pdfjs-views-manager-view-selector-button-label">Vues</span>
                        </button>
                        <menu id="viewsManagerSelectorOptions" role="listbox" class="popupMenu withMark">
                          <li>
                            <button id="thumbnailsViewMenu" role="option" type="button" tabindex="-1">
                              <span data-l10n-id="pdfjs-views-manager-pages-option-label">Pages</span>
                            </button>
                          </li>
                          <li>
                            <button id="outlinesViewMenu" role="option" type="button" tabindex="-1" disabled="">
                              <span data-l10n-id="pdfjs-views-manager-outlines-option-label">Signets du document</span>
                            </button>
                          </li>
                          <li>
                            <button id="attachmentsViewMenu" role="option" type="button" tabindex="-1" disabled="">
                              <span data-l10n-id="pdfjs-views-manager-attachments-option-label">Pièces jointes</span>
                            </button>
                          </li>
                          <li>
                            <button id="layersViewMenu" role="option" type="button" tabindex="-1" disabled="">
                              <span data-l10n-id="pdfjs-views-manager-layers-option-label">Calques</span>
                            </button>
                          </li>
                        </menu>
                      </div>
                      <span id="viewsManagerHeaderLabel" class="viewsManagerLabel"></span>
                      <button id="viewsManagerAddFileButton" class="toolbarButton viewsManagerButton" type="button" tabindex="0" data-l10n-id="pdfjs-views-manager-add-file-button" hidden="true" title="Ajouter un fichier">
                        <span data-l10n-id="pdfjs-views-manager-add-file-button-label">Ajouter un fichier</span>
                      </button>
                      <button id="viewsManagerCurrentOutlineButton" class="toolbarButton viewsManagerButton" type="button" tabindex="0" data-l10n-id="pdfjs-current-outline-item-button" hidden="true" title="Trouver l’élément de plan actuel" disabled="">
                        <span data-l10n-id="pdfjs-current-outline-item-button-label">Élément de plan actuel</span>
                      </button>
                    </div>
                    <div id="viewsManagerStatus">
                      <div id="viewsManagerStatusAction">
                        <span id="viewsManagerStatusActionLabel" class="viewsManagerStatusLabel" data-l10n-id="pdfjs-views-manager-pages-status-none-action-label">Sélectionner des pages</span>
                        <div id="actionSelector">
                          <button id="viewsManagerStatusActionButton" class="viewsManagerButton hasPopupMenu" type="button" tabindex="0" aria-haspopup="menu" aria-controls="viewsManagerStatusActionOptions" aria-expanded="false" hidden="">
                            <span data-l10n-id="pdfjs-views-manager-pages-status-action-button-label">Gérer</span>
                          </button>
                          <menu id="viewsManagerStatusActionOptions" class="popupMenu">
                            <li>
                              <button id="viewsManagerStatusActionCopy" class="noIcon" role="menuitem" type="button" tabindex="-1" disabled="">
                                <span data-l10n-id="pdfjs-views-manager-pages-status-copy-button-label">Copier</span>
                              </button>
                            </li>
                            <li>
                              <button id="viewsManagerStatusActionCut" class="noIcon" role="menuitem" type="button" tabindex="-1" disabled="">
                                <span data-l10n-id="pdfjs-views-manager-pages-status-cut-button-label">Couper</span>
                              </button>
                            </li>
                            <li>
                              <button id="viewsManagerStatusActionDelete" class="noIcon" role="menuitem" type="button" tabindex="-1" disabled="">
                                <span data-l10n-id="pdfjs-views-manager-pages-status-delete-button-label">Supprimer</span>
                              </button>
                            </li>
                            <li>
                              <button id="viewsManagerStatusActionSaveAs" class="noIcon" role="menuitem" type="button" tabindex="-1" disabled="">
                                <span data-l10n-id="pdfjs-views-manager-pages-status-save-as-button-label">Enregistrer sous…</span>
                              </button>
                            </li>
                          </menu>
                        </div>
                      </div>
                      <div id="viewsManagerStatusUndo" class="hidden">
                        <span class="viewsManagerStatusLabel" data-l10n-id="pdfjs-views-manager-status-undo-cut-label" data-l10n-args="{&quot;count&quot;: 0}">1 page coupée</span>
                        <div>
                          <button id="viewsManagerStatusUndoButton" class="viewsManagerButton" type="button" tabindex="0">
                            <span data-l10n-id="pdfjs-views-manager-status-undo-button-label">Annuler</span>
                          </button>
                          <button id="viewsManagerStatusUndoCloseButton" class="toolbarButton viewsManagerButton viewsCloseButton" type="button" tabindex="0" data-l10n-id="pdfjs-views-manager-status-close-button" title="Fermer">
                            <span data-l10n-id="pdfjs-views-manager-status-close-button-label">Fermer</span>
                          </button>
                        </div>
                      </div>
                      <div id="viewsManagerStatusWarning" class="hidden">
                        <span class="viewsManagerStatusLabel"></span>
                        <button id="viewsManagerStatusWarningCloseButton" class="toolbarButton viewsManagerButton viewsCloseButton" type="button" tabindex="0" data-l10n-id="pdfjs-views-manager-status-close-button" title="Fermer">
                          <span data-l10n-id="pdfjs-views-manager-status-close-button-label">Fermer</span>
                        </button>
                      </div>
                      <div id="viewsManagerStatusWaiting" class="hidden">
                        <span class="viewsManagerStatusLabel"></span>
                        <button id="viewsManagerStatusWaitingCloseButton" class="toolbarButton viewsManagerButton viewsCloseButton" type="button" tabindex="0" data-l10n-id="pdfjs-views-manager-status-close-button" title="Fermer">
                          <span data-l10n-id="pdfjs-views-manager-status-close-button-label">Fermer</span>
                        </button>
                      </div>
                    </div>
                  </div>
                  <div id="viewsManagerContent" tabindex="-1">
                    <div id="thumbnailsView" class="thumbnailsView hidden" tabindex="-1"><div class="thumbnail" page-number="1" page-id="1"><div class="thumbnailImageContainer missingThumbnailImage" role="button" tabindex="0" draggable="false" page-number="1" style="height: 89px;" aria-current="page"><img></div></div><div class="thumbnail" page-number="2" page-id="2"><div class="thumbnailImageContainer missingThumbnailImage" role="button" tabindex="-1" draggable="false" page-number="2" style="height: 89px;"><img></div></div><div class="thumbnail" page-number="3" page-id="3"><div class="thumbnailImageContainer missingThumbnailImage" role="button" tabindex="-1" draggable="false" page-number="3" style="height: 89px;"><img></div></div><div class="thumbnail" page-number="4" page-id="4"><div class="thumbnailImageContainer missingThumbnailImage" role="button" tabindex="-1" draggable="false" page-number="4" style="height: 89px;"><img></div></div><div class="thumbnail" page-number="5" page-id="5"><div class="thumbnailImageContainer missingThumbnailImage" role="button" tabindex="-1" draggable="false" page-number="5" style="height: 89px;"><img></div></div><div class="thumbnail" page-number="6" page-id="6"><div class="thumbnailImageContainer missingThumbnailImage" role="button" tabindex="-1" draggable="false" page-number="6" style="height: 89px;"><img></div></div><div class="thumbnail" page-number="7" page-id="7"><div class="thumbnailImageContainer missingThumbnailImage" role="button" tabindex="-1" draggable="false" page-number="7" style="height: 89px;"><img></div></div><div class="thumbnail" page-number="8" page-id="8"><div class="thumbnailImageContainer missingThumbnailImage" role="button" tabindex="-1" draggable="false" page-number="8" style="height: 89px;"><img></div></div><div class="thumbnail" page-number="9" page-id="9"><div class="thumbnailImageContainer missingThumbnailImage" role="button" tabindex="-1" draggable="false" page-number="9" style="height: 89px;"><img></div></div><div class="thumbnail" page-number="10" page-id="10"><div class="thumbnailImageContainer missingThumbnailImage" role="button" tabindex="-1" draggable="false" page-number="10" style="height: 89px;"><img></div></div></div>
                    <div id="outlinesView" class="treeView hidden"></div>
                    <div id="attachmentsView" class="hidden"></div>
                    <div id="layersView" class="treeView hidden"></div>
                  </div>
                  <div id="viewsManagerResizer" class="sidebarResizer" role="separator" aria-controls="viewsManager" tabindex="0" data-l10n-id="pdfjs-views-manager-sidebar-resizer" aria-label="Redimensionner le panneau latéral" aria-valuemin="0" aria-valuemax="50" aria-valuenow="0"></div>
                </div>
                <!-- sidebarContainer -->

                <div class="toolbarButtonSpacer"></div>
                <div class="toolbarButtonWithContainer">
                  <button id="viewFindButton" class="toolbarButton hidden" type="button" tabindex="0" data-l10n-id="pdfjs-findbar-button" aria-expanded="false" aria-controls="findbar" title="Rechercher dans le document">
                    <span data-l10n-id="pdfjs-findbar-button-label">Rechercher</span>
                  </button>
                  <div class="hidden doorHanger toolbarHorizontalGroup" id="findbar">
                    <div id="findInputContainer" class="toolbarHorizontalGroup">
                      <span class="loadingInput end toolbarHorizontalGroup">
                        <input id="findInput" class="toolbarField" tabindex="0" data-l10n-id="pdfjs-find-input" aria-invalid="false" title="Rechercher" placeholder="Rechercher dans le document…">
                      </span>
                      <div class="toolbarHorizontalGroup">
                        <button id="findPreviousButton" class="toolbarButton" type="button" tabindex="0" data-l10n-id="pdfjs-find-previous-button" title="Trouver l’occurrence précédente de l’expression">
                          <span data-l10n-id="pdfjs-find-previous-button-label">Précédent</span>
                        </button>
                        <div class="splitToolbarButtonSeparator"></div>
                        <button id="findNextButton" class="toolbarButton" type="button" tabindex="0" data-l10n-id="pdfjs-find-next-button" title="Trouver la prochaine occurrence de l’expression">
                          <span data-l10n-id="pdfjs-find-next-button-label">Suivant</span>
                        </button>
                      </div>
                    </div>

                    <div id="findbarOptionsOneContainer" class="toolbarHorizontalGroup">
                      <div class="toggleButton toolbarLabel">
                        <input type="checkbox" id="findHighlightAll" tabindex="0">
                        <label for="findHighlightAll" data-l10n-id="pdfjs-find-highlight-checkbox">Tout surligner</label>
                      </div>
                      <div class="toggleButton toolbarLabel">
                        <input type="checkbox" id="findMatchCase" tabindex="0">
                        <label for="findMatchCase" data-l10n-id="pdfjs-find-match-case-checkbox-label">Respecter la casse</label>
                      </div>
                    </div>
                    <div id="findbarOptionsTwoContainer" class="toolbarHorizontalGroup">
                      <div class="toggleButton toolbarLabel">
                        <input type="checkbox" id="findMatchDiacritics" tabindex="0">
                        <label for="findMatchDiacritics" data-l10n-id="pdfjs-find-match-diacritics-checkbox-label">Respecter les accents et diacritiques</label>
                      </div>
                      <div class="toggleButton toolbarLabel">
                        <input type="checkbox" id="findEntireWord" tabindex="0">
                        <label for="findEntireWord" data-l10n-id="pdfjs-find-entire-word-checkbox-label">Mots entiers</label>
                      </div>
                    </div>

                    <div id="findbarMessageContainer" class="toolbarHorizontalGroup" aria-live="polite">
                      <span id="findResultsCount" class="toolbarLabel"></span>
                      <span id="findMsg" class="toolbarLabel"></span>
                    </div>
                  </div>
                  <!-- findbar -->
                </div>
                <div class="toolbarHorizontalGroup hiddenSmallView">
                  <button class="toolbarButton" type="button" id="previous" tabindex="0" data-l10n-id="pdfjs-previous-button" title="Page précédente" disabled="">
                    <span data-l10n-id="pdfjs-previous-button-label">Précédent</span>
                  </button>
                  <div class="splitToolbarButtonSeparator"></div>
                  <button class="toolbarButton" type="button" id="next" tabindex="0" data-l10n-id="pdfjs-next-button" title="Page suivante">
                    <span data-l10n-id="pdfjs-next-button-label">Suivant</span>
                  </button>
                </div>
                <div class="toolbarHorizontalGroup">
                  <span class="loadingInput start toolbarHorizontalGroup">
                    <input type="number" id="pageNumber" class="toolbarField" value="1" min="1" tabindex="0" data-l10n-id="pdfjs-page-input" autocomplete="off" title="Page" max="10">
                  </span>
                  <span id="numPages" class="toolbarLabel" data-l10n-id="pdfjs-of-pages" data-l10n-args="{&quot;pagesCount&quot;:10}">sur 10</span>
                </div>
              </div>
              <div id="toolbarViewerMiddle" class="toolbarHorizontalGroup">
                <div class="toolbarHorizontalGroup">
                  <button id="zoomOutButton" class="toolbarButton" type="button" tabindex="0" data-l10n-id="pdfjs-zoom-out-button" title="Zoom arrière">
                    <span data-l10n-id="pdfjs-zoom-out-button-label">Zoom arrière</span>
                  </button>
                  <div class="splitToolbarButtonSeparator"></div>
                  <button id="zoomInButton" class="toolbarButton" type="button" tabindex="0" data-l10n-id="pdfjs-zoom-in-button" title="Zoom avant">
                    <span data-l10n-id="pdfjs-zoom-in-button-label">Zoom avant</span>
                  </button>
                </div>
                <span id="scaleSelectContainer" class="dropdownToolbarButton">
                  <select id="scaleSelect" tabindex="0" data-l10n-id="pdfjs-zoom-select" title="Zoom">
                    <option id="pageAutoOption" value="auto" selected="selected" data-l10n-id="pdfjs-page-scale-auto">Zoom automatique</option>
                    <option id="pageActualOption" value="page-actual" data-l10n-id="pdfjs-page-scale-actual">Taille réelle</option>
                    <option id="pageFitOption" value="page-fit" data-l10n-id="pdfjs-page-scale-fit">Page entière</option>
                    <option id="pageWidthOption" value="page-width" data-l10n-id="pdfjs-page-scale-width">Pleine largeur</option>
                    <option id="customScaleOption" value="custom" disabled="disabled" hidden="true" data-l10n-id="pdfjs-page-scale-percent" data-l10n-args="{ &quot;scale&quot;: 0 }">0&nbsp;%</option>
                    <option value="0.5" data-l10n-id="pdfjs-page-scale-percent" data-l10n-args="{ &quot;scale&quot;: 50 }">50&nbsp;%</option>
                    <option value="0.75" data-l10n-id="pdfjs-page-scale-percent" data-l10n-args="{ &quot;scale&quot;: 75 }">75&nbsp;%</option>
                    <option value="1" data-l10n-id="pdfjs-page-scale-percent" data-l10n-args="{ &quot;scale&quot;: 100 }">100&nbsp;%</option>
                    <option value="1.25" data-l10n-id="pdfjs-page-scale-percent" data-l10n-args="{ &quot;scale&quot;: 125 }">125&nbsp;%</option>
                    <option value="1.5" data-l10n-id="pdfjs-page-scale-percent" data-l10n-args="{ &quot;scale&quot;: 150 }">150&nbsp;%</option>
                    <option value="2" data-l10n-id="pdfjs-page-scale-percent" data-l10n-args="{ &quot;scale&quot;: 200 }">200&nbsp;%</option>
                    <option value="3" data-l10n-id="pdfjs-page-scale-percent" data-l10n-args="{ &quot;scale&quot;: 300 }">300&nbsp;%</option>
                    <option value="4" data-l10n-id="pdfjs-page-scale-percent" data-l10n-args="{ &quot;scale&quot;: 400 }">400&nbsp;%</option>
                  </select>
                </span>
              </div>
              <div id="toolbarViewerRight" class="toolbarHorizontalGroup">
                <div id="editorModeButtons" class="toolbarHorizontalGroup">
                  <div id="editorComment" class="toolbarButtonWithContainer">
                    <button id="editorCommentButton" class="toolbarButton" type="button" tabindex="0" aria-expanded="false" aria-haspopup="true" aria-controls="editorCommentParamsToolbar" data-l10n-id="pdfjs-editor-comment-button" title="Commenter" aria-label="Commenter">
                      <span data-l10n-id="pdfjs-editor-comment-button-label">Commenter</span>
                    </button>
                    <div class="editorParamsToolbar hidden menu" id="editorCommentParamsToolbar" style="inset-inline-start: 239px;">
                      <div id="editorCommentsSidebar" class="menuContainer comment sidebar" role="landmark" aria-labelledby="editorCommentsSidebarHeader" hidden="">
                        <div id="editorCommentsSidebarResizer" class="sidebarResizer" role="separator" aria-controls="editorCommentsSidebar" tabindex="0" aria-valuemin="180" aria-valuemax="632" aria-valuenow="0"></div>
                        <div id="editorCommentsSidebarHeader" role="heading" aria-level="2">
                          <span class="commentCount">
                            <span id="editorCommentsSidebarTitle" data-l10n-id="pdfjs-editor-comments-sidebar-title" data-l10n-args="{ &quot;count&quot;: 0 }">Commentaire</span>
                            <span id="editorCommentsSidebarCount"></span>
                          </span>
                          <button id="editorCommentsSidebarCloseButton" type="button" tabindex="0" data-l10n-id="pdfjs-editor-comments-sidebar-close-button" title="Fermer le panneau latéral" aria-label="Fermer le panneau latéral">
                            <span data-l10n-id="pdfjs-editor-comments-sidebar-close-button-label">Fermer le panneau latéral</span>
                          </button>
                        </div>
                        <div id="editorCommentsSidebarListContainer" tabindex="-1">
                          <ul id="editorCommentsSidebarList"></ul>
                        </div>
                      </div>
                    </div>
                  </div>
                  <div id="editorSignature" class="toolbarButtonWithContainer">
                    <button id="editorSignatureButton" class="toolbarButton" type="button" tabindex="0" aria-expanded="false" aria-haspopup="true" aria-controls="editorSignatureParamsToolbar" data-l10n-id="pdfjs-editor-signature-button" title="Ajouter une signature">
                      <span data-l10n-id="pdfjs-editor-signature-button-label">Ajouter une signature</span>
                    </button>
                    <div class="editorParamsToolbar hidden doorHangerRight menu" id="editorSignatureParamsToolbar">
                      <div id="addSignatureDoorHanger" class="menuContainer" role="region" data-l10n-id="pdfjs-editor-add-signature-container" aria-label="Contrôles de signature et signatures enregistrées">
                        <button id="editorSignatureAddSignature" class="toolbarButton labeled" type="button" tabindex="0" data-l10n-id="pdfjs-editor-signature-add-signature-button" title="Ajouter une nouvelle signature">
                          <span data-l10n-id="pdfjs-editor-signature-add-signature-button-label" class="editorParamsLabel">Ajouter une nouvelle signature</span>
                        </button>
                      </div>
                    </div>
                  </div>
                  <div id="editorHighlight" class="toolbarButtonWithContainer">
                    <button id="editorHighlightButton" class="toolbarButton" type="button" aria-expanded="false" aria-haspopup="true" aria-controls="editorHighlightParamsToolbar" tabindex="0" data-l10n-id="pdfjs-editor-highlight-button" title="Surligner">
                      <span data-l10n-id="pdfjs-editor-highlight-button-label">Surligner</span>
                    </button>
                    <div class="editorParamsToolbar hidden doorHangerRight" id="editorHighlightParamsToolbar">
                      <div id="highlightParamsToolbarContainer" class="editorParamsToolbarContainer">
                        <div id="editorHighlightColorPicker" class="colorPicker">
                          <span id="highlightColorPickerLabel" class="editorParamsLabel" data-l10n-id="pdfjs-editor-highlight-colorpicker-label">Couleur de surlignage</span>
                        <div class="dropdown" role="listbox" aria-multiselectable="false" aria-orientation="horizontal" data-l10n-id="pdfjs-editor-colorpicker-dropdown" aria-label="Choix de couleurs"><button tabindex="0" role="option" data-color="#FFFF98" title="Jaune" data-l10n-id="pdfjs-editor-colorpicker-yellow" aria-selected="true"><span class="swatch" style="background-color: rgb(255, 255, 152);"></span></button><button tabindex="0" role="option" data-color="#53FFBC" title="Vert" data-l10n-id="pdfjs-editor-colorpicker-green" aria-selected="false"><span class="swatch" style="background-color: rgb(83, 255, 188);"></span></button><button tabindex="0" role="option" data-color="#80EBFF" title="Bleu" data-l10n-id="pdfjs-editor-colorpicker-blue" aria-selected="false"><span class="swatch" style="background-color: rgb(128, 235, 255);"></span></button><button tabindex="0" role="option" data-color="#FFCBE6" title="Rose" data-l10n-id="pdfjs-editor-colorpicker-pink" aria-selected="false"><span class="swatch" style="background-color: rgb(255, 203, 230);"></span></button><button tabindex="0" role="option" data-color="#FF4F5F" title="Rouge" data-l10n-id="pdfjs-editor-colorpicker-red" aria-selected="false"><span class="swatch" style="background-color: rgb(255, 79, 95);"></span></button></div></div>
                        <div id="editorHighlightThickness">
                          <label for="editorFreeHighlightThickness" class="editorParamsLabel" data-l10n-id="pdfjs-editor-free-highlight-thickness-input">Épaisseur</label>
                          <div class="thicknessPicker">
                            <input type="range" id="editorFreeHighlightThickness" class="editorParamsSlider" data-l10n-id="pdfjs-editor-free-highlight-thickness-title" value="12" min="8" max="24" step="1" tabindex="0" title="Modifier l’épaisseur pour le surlignage d’éléments non textuels">
                          </div>
                        </div>
                        <div id="editorHighlightVisibility">
                          <div class="divider"></div>
                          <div class="toggler">
                            <label for="editorHighlightShowAll" class="editorParamsLabel" data-l10n-id="pdfjs-editor-highlight-show-all-button-label">Tout afficher</label>
                            <button id="editorHighlightShowAll" class="toggle-button" type="button" data-l10n-id="pdfjs-editor-highlight-show-all-button" aria-pressed="true" tabindex="0" title="Tout afficher"></button>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                  <div id="editorFreeText" class="toolbarButtonWithContainer">
                    <button id="editorFreeTextButton" class="toolbarButton" type="button" aria-expanded="false" aria-haspopup="true" aria-controls="editorFreeTextParamsToolbar" tabindex="0" data-l10n-id="pdfjs-editor-free-text-button" title="Texte">
                      <span data-l10n-id="pdfjs-editor-free-text-button-label">Texte</span>
                    </button>
                    <div class="editorParamsToolbar hidden doorHangerRight" id="editorFreeTextParamsToolbar">
                      <div class="editorParamsToolbarContainer">
                        <div class="editorParamsSetter">
                          <label for="editorFreeTextColor" class="editorParamsLabel" data-l10n-id="pdfjs-editor-free-text-color-input">Couleur</label>
                          <input type="color" id="editorFreeTextColor" class="editorParamsColor" tabindex="0">
                        </div>
                        <div class="editorParamsSetter">
                          <label for="editorFreeTextFontSize" class="editorParamsLabel" data-l10n-id="pdfjs-editor-free-text-size-input">Taille</label>
                          <input type="range" id="editorFreeTextFontSize" class="editorParamsSlider" value="10" min="5" max="100" step="1" tabindex="0">
                        </div>
                      </div>
                    </div>
                  </div>
                  <div id="editorInk" class="toolbarButtonWithContainer">
                    <button id="editorInkButton" class="toolbarButton" type="button" aria-expanded="false" aria-haspopup="true" aria-controls="editorInkParamsToolbar" tabindex="0" data-l10n-id="pdfjs-editor-ink-button" title="Dessiner">
                      <span data-l10n-id="pdfjs-editor-ink-button-label">Dessiner</span>
                    </button>
                    <div class="editorParamsToolbar hidden doorHangerRight" id="editorInkParamsToolbar">
                      <div class="editorParamsToolbarContainer">
                        <div class="editorParamsSetter">
                          <label for="editorInkColor" class="editorParamsLabel" data-l10n-id="pdfjs-editor-ink-color-input">Couleur</label>
                          <input type="color" id="editorInkColor" class="editorParamsColor" tabindex="0">
